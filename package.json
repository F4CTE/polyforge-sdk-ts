{
  "name": "@polyforge/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the Polyforge trading platform REST API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/emit-esm.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "polyforge",
    "trading",
    "sdk",
    "api",
    "crypto",
    "defi",
    "strategies",
    "portfolio",
    "typescript",
    "rest-client"
  ],
  "author": "Polyforge",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0",
    "vitest": "^1.6.0"
  }
}
